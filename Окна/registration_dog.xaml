<Window x:Class="Клуб_6.Окна.registration_dog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="registration_dog"  Height="674" Width="800"    
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Заголовок -->
                <TextBlock Text="РЕГИСТРАЦИЯ СОБАКИ" 
               FontSize="24" 
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,0,0,20"/>

                <!-- Основные поля -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Номер чипа*:" FontWeight="Bold" Foreground="White"/>
                        <TextBox x:Name="txtChip" FontSize="14" Padding="5" Height="30" Width="351,6"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: 123456"/>

                        <!-- Кличка -->
                        <TextBlock Text="Кличка*:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtName" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: ASTANA STAR"/>

                        <!-- Порода -->
                        <TextBlock Text="Порода*:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtBreed" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: DD"/>

                        <!-- Окрас -->
                        <TextBlock Text="Окрас:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtColor" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: Коричневый"/>
                        <!-- Дата рождения -->
                        <TextBlock Text="Дата рождения*:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <DatePicker x:Name="dpBirthDate" FontSize="14" Height="30" Width="200"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Правая колонка -->
                    <StackPanel Grid.Column="2">
                        <!-- Рост -->
                        <TextBlock Text="Рост (см):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtHeight" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: 70"/>

                        <!-- Вес -->
                        <TextBlock Text="Вес (кг):" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtWeight" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: 65"/>

                        <!-- Пол -->
                        <TextBlock Text="Пол*:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbMale" Content="Кобель" FontSize="14" Margin="0,0,20,0" Foreground="White"/>
                            <RadioButton x:Name="rbFemale" Content="Сука" FontSize="14" Foreground="White"/>
                        </StackPanel>

                        <!-- Питомник -->
                        <TextBlock Text="Питомник:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="cmbKennel" FontSize="14" Height="30" Width="300"/>
                            <Button x:Name="btnAddKennel" Content="+" 
                            Click="AddKennelButton_Click" Margin="5,0,0,0" Padding="10,5" Width="40"
                            ToolTip="Добавить новый питомник"/>
                        </StackPanel>

                        <!-- Владелец -->
                        <TextBlock Text="Владелец *:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="cmbOwner" FontSize="14" Height="30" Width="300"/>
                            <Button x:Name="btnAddOwner" Content="+" 
                            Click="AddOwnerButton_Click" Margin="5,0,0,0" Padding="10,5" Width="40"
                            ToolTip="Добавить нового владельца"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Родители -->
                <TextBlock Text="РОДИТЕЛИ" FontWeight="Bold" Foreground="White" 
               FontSize="16" Margin="0,30,0,10" HorizontalAlignment="Center"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Мать -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Мать (кличка):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMother" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: ASTANA STAR"/>
                    </StackPanel>

                    <!-- Отец -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Отец (кличка):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFather" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"
                             Tag="Например: SUDOSTSTERN LOKI"/>
                    </StackPanel>
                </Grid>

                <!-- Статус -->
                <CheckBox x:Name="chkIsAlive" Content="Собака жива" FontWeight="Bold" Foreground="White" 
                  Margin="0,20,0,0" IsChecked="True"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Border CornerRadius="20" 
            BorderThickness="1" 
            Height="45" 
            Width="150"
            Background="#444444"
            Margin="0,0,20,0">
                        <Button x:Name="btnBack" 
                Content="НАЗАД" 
                Click="BackButton_Click"
                Style="{StaticResource ButtonStyleTHREE}"
                FontWeight="Bold"
                FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
            BorderThickness="1" 
            Height="45" 
            Width="160"
            Background="#444444"
            Margin="0,0,20,0">
                        <Button x:Name="btnSave" 
                Content="СОХРАНИТЬ" 
                Click="SaveButton_Click"
                Style="{StaticResource ButtonStyle}"
                FontWeight="Bold"
                FontSize="25" />
                    </Border>

                    <Border CornerRadius="20" 
            BorderThickness="1" 
            Height="45" 
            Width="150"
            Background="#6E0A0F"
            Margin="0,0,0,0">
                        <Button x:Name="btnClose" 
                Content="ВЫХОД" 
                Click="CloseButton_Click"
                Style="{StaticResource ButtonStyleTWO}"
                FontWeight="Bold"
                FontSize="25"/>
                    </Border>
                </StackPanel>

                <!-- Примечание -->
                <TextBlock Text="* - обязательные поля для заполнения" 
               FontSize="12" 
               Foreground="White" 
               Margin="0,20,0,0"
               HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
