<Window x:Class="Клуб_6.Окна.registration_owner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="registration_owner" 
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Заголовок -->
                <TextBlock Text="РЕГИСТРАЦИЯ ВЛАДЕЛЬЦА" 
               FontSize="24" 
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,0,0,20"/>

                <!-- ФИО раздельно -->
                <TextBlock Text="ФИО" 
               FontSize="16" FontWeight="Bold" Foreground="White" 
               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Фамилия * -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Фамилия *:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtLastName" FontSize="14" Padding="5" Height="30" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" 
                             Tag="Например: Петров"/>
                    </StackPanel>

                    <!-- Имя * -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Имя *:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFirstName" FontSize="14" Padding="5" Height="30" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" 
                             Tag="Например: Петр"/>
                    </StackPanel>

                    <!-- Отчество -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Отчество:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMiddleName" FontSize="14" Padding="5" Height="30" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" 
                             Tag="Например: Петрович"/>
                    </StackPanel>
                </Grid>

                <!-- Контактная информация -->
                <TextBlock Text="КОНТАКТНАЯ ИНФОРМАЦИЯ" 
               FontSize="16" FontWeight="Bold" Foreground="White" 
               HorizontalAlignment="Center" Margin="0,20,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка -->
                    <StackPanel Grid.Column="0">
                        <!-- Телефон * -->
                        <TextBlock Text="Телефон *:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <xctk:MaskedTextBox x:Name="txtPhone"
                             Mask="+7(000)000-00-00"
                             FontSize="14"
                             Height="30"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#CCCCCC"
                             BorderThickness="1"
                             PromptChar="_"
                             PreviewMouseDown="txtPhone_PreviewMouseDown"
                             GotFocus="txtPhone_GotFocus"/>

                        <!-- Email -->
                        <TextBlock Text="Email:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtEmail" FontSize="14" Padding="5" Height="30" 
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="Например: Kennel@example.com"/>

                        <TextBlock Text="Дата рождения (дд.мм.гггг):" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <DatePicker x:Name="dpBirthDate" FontSize="14" Height="30"  />

                    </StackPanel>

                    <!-- Правая колонка -->
                    <StackPanel Grid.Column="2">
                        <!-- Город -->
                        <TextBlock Text="Город:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCity" FontSize="14" Padding="5" Height="30"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="Например: Алматы"/>

                        <!-- Адрес -->
                        <TextBlock Text="Адрес:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtAddress" FontSize="14" Padding="5" Height="30" 
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Tag="Например: ул. Ленина, д. 10, кв. 5"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Border CornerRadius="20" 
            BorderThickness="1" 
            Height="45" 
            Width="150"
            Background="#444444"
            Margin="0,0,20,0">
                        <Button x:Name="btnBack" 
                Content="НАЗАД" 
                Click="BackButton_Click"
                Style="{StaticResource ButtonStyleTHREE}"
                FontWeight="Bold"
                FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
            BorderThickness="1" 
            Height="45" 
            Width="160"
            Background="#444444"
            Margin="0,0,20,0">
                        <Button x:Name="btnSave" 
                Content="СОХРАНИТЬ" 
                Click="SaveButton_Click"
                Style="{StaticResource ButtonStyle}"
                FontWeight="Bold"
                FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
            BorderThickness="1" 
            Height="45" 
            Width="150"
            Background="#6E0A0F"
            Margin="0,0,0,0" Cursor="">
                        <Button x:Name="btnExit" 
                Content="ВЫХОД" 
                Click="ExitButton_Click"
                Style="{StaticResource ButtonStyleTWO}"
                FontWeight="Bold"
                FontSize="25"/>
                    </Border>
                </StackPanel>

                <!-- Примечание -->
                <TextBlock Text="* - обязательные поля для заполнения" 
               FontSize="12" 
               Foreground="#FFD700" 
               FontWeight="Bold"
               Margin="0,20,0,0"
               HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
