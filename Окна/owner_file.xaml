<Window x:Class="Клуб_6.Окна.owner_file"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="owner_file"     
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <Grid>
            <!-- Используем Grid для центрирования -->
            <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0" >
                <TextBlock Text="КАРТОТЕКА ВЛАДЕЛЬЦЕВ" 
                HorizontalAlignment="Center" 
                FontSize="35" 
                FontWeight="Bold"/>
                <Border Grid.Row="1" Margin="50,10,50,10" Background="White" CornerRadius="10">
                    <ListView Name="BoxOwner" 
                   ItemsSource="{Binding OwnerList}"
                   FontSize="14"
                   Height="670" 
                   BorderThickness="0" 
                   Width="1500"
                   AlternationCount="2"
                   Margin="0,10,0,0"
                   SelectionMode="Single"
                              MouseDoubleClick="BoxEvents_MouseDoubleClick">

                        <ListView.Resources>
                            <!-- Стиль для заголовков столбцов -->
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="Background" Value="#08541C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Height" Value="35"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="#C7C7C7"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#ACDDE7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Фамилия" Width="120" DisplayMemberBinding="{Binding LastName}"/>
                                <GridViewColumn Header="Имя" Width="100" DisplayMemberBinding="{Binding FirstName}"/>
                                <GridViewColumn Header="Отчество" Width="120" DisplayMemberBinding="{Binding MiddleName}"/>
                                <GridViewColumn Header="Телефон" Width="150" DisplayMemberBinding="{Binding Phone}"/>
                                <GridViewColumn Header="Собаки" Width="250">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DogsNames}" 
                                    TextWrapping="Wrap"
                                    ToolTip="{Binding DogsNames}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <Border CornerRadius="20" 
                 BorderThickness="1" 
                 Height="45" 
                 Width="150"
                 Background="#444444"
                 Margin="0,-25,0,0"
                 HorizontalAlignment="Left">
                        <Button x:Name="btnCalendar" 
                     Content="НАЗАД" 
                     Click="btnBack_Click"
                     Style="{StaticResource ButtonStyleTHREE}"
                     FontWeight="Bold"
                     FontSize="25"/>
                    </Border>

                    <Border Background="Transparent"  Width="20"/>

                    <Border CornerRadius="20" 
                 BorderThickness="1" 
                 Height="45" 
                 Width="230"
                 Background="#444444"
                 Margin="0,-25,0,0"
                 HorizontalAlignment="Left" >
                        <Button x:Name="btnChange" 
                     Content="ОТКРЫТЬ КАРТУ" 
                     Click="btnChange_Click"
                     Style="{StaticResource ButtonStyle}"
                     FontWeight="Bold"
                     FontSize="25"/>
                    </Border>

                    <Border Background="Transparent"  Width="20"/>

                    <Border CornerRadius="20" 
                     BorderThickness="1" 
                     Height="45" 
                     Width="180"
                     Background="#6E0A0F"
                     Margin="0,-25,0,0"
                     HorizontalAlignment="Left">
                        <Button x:Name="btnDelete" 
                     Content="УДАЛИТЬ" 
                     Click="btnDelete_Click"
                     Style="{StaticResource ButtonStyleTWO}"
                     FontWeight="Bold"
                     FontSize="25" Height="43" VerticalAlignment="Top"/>
                    </Border>

                    <Border Background="Transparent"  Width="20"/>

                    <Border CornerRadius="20" 
                 BorderThickness="1" 
                 Height="45" 
                 Width="150"
                 Background="#6E0A0F"
                 Margin="0,-25,0,0">
                        <Button x:Name="btnExit" 
                     Content="ВЫХОД" 
                     Click="btnExit_Click"
                     Style="{StaticResource ButtonStyleTWO}"
                     FontWeight="Bold"
                     FontSize="25"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
