<Window x:Class="Клуб_6.Окна.dog_file"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="dog_file" 
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
            Text="КАРТОТЕКА СОБАК" 
            HorizontalAlignment="Center" 
            FontSize="35" 
            FontWeight="Bold"
            Margin="0,20,0,-10"/>
            <!-- Используем Grid для центрирования -->
            <Border Grid.Row="1" Margin="50,20,50,10" Background="White" CornerRadius="10">
                <StackPanel>
                    <ListView Name="BoxDog" 
                    ItemsSource="{Binding DogList}"
                    FontSize="14"
                    Height="670" 
                    BorderThickness="0" 
                    Width="1500"
                    AlternationCount="2"
                    Margin="0,10,0,0"
                    SelectionMode="Single"
                     MouseDoubleClick="BoxEvents_MouseDoubleClick">
                    

                        <ListView.Resources>
                            <!-- Стиль для заголовков столбцов -->
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="Background" Value="#08541C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Height" Value="35"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="#C7C7C7"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#ACDDE7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Чип" Width="100" DisplayMemberBinding="{Binding ChipNumber}"/>
                                <GridViewColumn Header="Кличка" Width="150" DisplayMemberBinding="{Binding DogName}"/>
                                <GridViewColumn Header="Порода" Width="150" DisplayMemberBinding="{Binding Breed}"/>
                                <GridViewColumn Header="Дата рождения" Width="120" DisplayMemberBinding="{Binding BirthDate, StringFormat=dd.MM.yyyy}"/>
                                <GridViewColumn Header="Статус (Жив)" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsAlive}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Пол" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Gender}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Владелец" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ВладелецФИО}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Рост (см)" Width="90" DisplayMemberBinding="{Binding HeightCm}"/>
                                <GridViewColumn Header="Вес (кг)" Width="90" DisplayMemberBinding="{Binding WeightKg}"/>
                                <GridViewColumn Header="Окрас" Width="100" DisplayMemberBinding="{Binding Color}"/>
                                <GridViewColumn Header="Питомник" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Kennel.KennelName}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>


            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="45" 
                Width="150"
                Background="#444444"
                Margin="0,-25,0,0"
                HorizontalAlignment="Left">
                    <Button x:Name="btnCalendar" 
                    Content="НАЗАД" 
                    Click="btnBack_Click"
                    Style="{StaticResource ButtonStyleTHREE}"
                    FontWeight="Bold"
                    FontSize="25"/>
                </Border>

                <Border Background="Transparent"  Width="20"/>

                <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="230"
                    Background="#444444"
                    Margin="0,-25,0,0"
                    HorizontalAlignment="Left" >
                    <Button x:Name="btnChange" 
                        Content="ОТКРЫТЬ КАРТУ" 
                        Click="btnChange_Click"
                        Style="{StaticResource ButtonStyle}"
                        FontWeight="Bold"
                        FontSize="25"/>
                </Border>

                <Border Background="Transparent"  Width="20"/>

                <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="150"
                    Background="#6E0A0F"
                    Margin="0,-25,0,0">
                    <Button x:Name="btnDelete" 
                        Content="УДАЛИТЬ" 
                        Click="DeleteButton_Click"
                        Style="{StaticResource ButtonStyleTWO}"
                        FontWeight="Bold"
                        FontSize="25"/>
                </Border>


                <Border Background="Transparent"  Width="20"/>

                <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="150"
                    Background="#6E0A0F"
                    Margin="0,-25,0,0">
                    <Button x:Name="btnExit" 
                        Content="ВЫХОД" 
                        Click="btnExit_Click"
                        Style="{StaticResource ButtonStyleTWO}"
                        FontWeight="Bold"
                        FontSize="25"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
