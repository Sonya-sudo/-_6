<Window x:Class="Клуб_6.Окна.dog_card"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="dog_card">
    <Border Background="#76AF2C">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Заголовок -->
                <TextBlock Text="КАРТОЧКА СОБАКИ" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Основные поля в 2 колонки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка -->
                    <StackPanel Grid.Column="0">
                        <!-- Чип -->
                        <TextBlock Text="Чип (номер):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtChip" FontSize="14" Padding="5" Height="30"/>
                        <!-- Кличка -->
                        <TextBlock Text="Кличка*:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtName" FontSize="14" Padding="5" Height="30"/>

                        <!-- Порода -->
                        <TextBlock Text="Порода*:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtBreed" FontSize="14" Padding="5" Height="30"/>

                        <!-- Окрас -->
                        <TextBlock Text="Окрас:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtColor" FontSize="14" Padding="5" Height="30"/>

                        <!-- Дата рождения -->
                        <TextBlock Text="Дата рождения:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <DatePicker x:Name="dpBirthDate" FontSize="14" Height="30"/>

                        <!-- Статус -->
                        <CheckBox x:Name="chkIsAlive" Content="Жив(а)" FontWeight="Bold" Foreground="White" 
                                  Margin="0,15,0,0" IsChecked="True"/>
                    </StackPanel>

                    <!-- Правая колонка -->
                    <StackPanel Grid.Column="2">
                        <!-- Рост -->
                        <TextBlock Text="Рост (см):" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtHeight" FontSize="14" Padding="5" Height="30"/>

                        <!-- Вес -->
                        <TextBlock Text="Вес (кг):" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtWeight" FontSize="14" Padding="5" Height="30"/>

                        <!-- Пол -->
                        <TextBlock Text="Пол*:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbMale" Content="Кобель" FontSize="14" Margin="0,0,20,0" Foreground="White"/>
                            <RadioButton x:Name="rbFemale" Content="Сука" FontSize="14" Foreground="White"/>
                        </StackPanel>

                        <!-- Питомник -->
                        <TextBlock Text="Питомник:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <ComboBox x:Name="cmbKennel" FontSize="14" Height="30" 
                                  DisplayMemberPath="DisplayText" SelectedValuePath="Kennel"/>

                        <TextBlock Text="Владелец:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <ComboBox x:Name="cmbOwner" FontSize="14" Height="30"
                                  DisplayMemberPath="DisplayText" SelectedValuePath="Owner"/>
                    </StackPanel>
                </Grid>

                <!-- Родители -->
                <TextBlock Text="РОДИТЕЛИ" FontWeight="Bold" Foreground="White" 
                           FontSize="16" Margin="0,30,0,10" HorizontalAlignment="Center"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Мать -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Мать (кличка):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMother" FontSize="14" Padding="5" Height="30"/>
                    </StackPanel>

                    <!-- Отец -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Отец (кличка):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFather" FontSize="14" Padding="5" Height="30"/>
                    </StackPanel>
                </Grid>

                <!-- Важные критерии оценки -->
                <Border BorderBrush="#08541C" BorderThickness="1" CornerRadius="5" 
                        Margin="0,30,0,20" Padding="10" Background="White">
                    <StackPanel>
                        <TextBlock Text="ПОДРОБНОСТИ" 
                                   FontWeight="Bold" 
                                   Foreground="#08541C" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <!-- ItemsControl для отображения важных критериев -->
                        <ItemsControl x:Name="importantCriteriaControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="0,0,0,8"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <!-- Название критерия -->
                                            <TextBlock Text="{Binding CriterionName}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="#08541C"
                                                       Margin="0,0,0,3"/>

                                            <!-- Выбранный вариант -->
                                            <TextBlock Text="{Binding SelectedOption}"
                                                       FontSize="13"
                                                       Foreground="#333333"
                                                       Margin="0,0,0,5"/>

                                            <!-- Мероприятие и дата -->
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding EventName}"
                                                           FontSize="11"
                                                           Foreground="#666666"/>
                                                <TextBlock Text="{Binding EventDate}"
                                                           FontSize="11"
                                                           Foreground="#666666"
                                                           Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Сообщение если нет важных критериев -->
                        <TextBlock x:Name="txtNoImportantCriteria"
                                   Text="Нет важных критериев оценки для этой собаки"
                                   FontStyle="Italic"
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Border CornerRadius="20" 
                            BorderThickness="1" 
                            Height="45" 
                            Width="170"
                            Background="#444444"
                            Margin="0,0,20,0">
                        <Button x:Name="btnSave" 
                                Content="СОХРАНИТЬ" 
                                Click="SaveButton_Click"
                                Style="{StaticResource ButtonStyle}"        
                                FontWeight="Bold"
                                FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                            BorderThickness="1" 
                            Height="45" 
                            Width="150"
                            Background="#6E0A0F"
                            Margin="0,0,0,0">
                        <Button x:Name="btnClose" 
                                Content="ЗАКРЫТЬ" 
                                Click="CloseButton_Click"
                                Style="{StaticResource ButtonStyleTWO}"
                                FontWeight="Bold"
                                FontSize="25"/>
                    </Border>
                </StackPanel>

                <!-- Примечание -->
                <TextBlock Text="* - обязательные поля для заполнения" 
                           FontSize="12" 
                           Foreground="White" 
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>