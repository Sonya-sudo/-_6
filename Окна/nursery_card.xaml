<Window x:Class="Клуб_6.Окна.nursery_card"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Icon="/Изображения/лапа.jpg"
        Title="nursery_card">

    <Border Background="#76AF2C">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Заголовок -->
                <Border CornerRadius="20" 
                        BorderThickness="1" 
                        Height="55" 
                        Width="410"
                        Background="#B0E75B"
                        Margin="0,2,20,0"
                        HorizontalAlignment="Center">
                    <TextBlock Text="КАРТОЧКА ПИТОМНИКА" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Блок Основная информация -->
                <Border Background="#B0E75B" 
                        CornerRadius="5" 
                        Padding="15" 
                        Margin="0,20,0,0"
                        HorizontalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="Black" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Название питомника:" FontWeight="Bold" Foreground="Black" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtName" FontSize="14" Padding="5" Height="30"
                                         Background="White"/>

                                <TextBlock Text="Дата основания:" FontWeight="Bold" Foreground="Black" Margin="0,10,0,5"/>
                                <DatePicker x:Name="dpFoundationDate" FontSize="14" Height="30" Background="White"/>

                                <TextBlock Text="Страна:" FontWeight="Bold" Foreground="Black" Margin="0,10,0,5"/>
                                <TextBox x:Name="txtCountry" FontSize="14" Padding="5" Height="30"
                                         Background="White"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Телефон:" FontWeight="Bold" Foreground="Black" Margin="0,0,0,5"/>
                                <xctk:MaskedTextBox x:Name="txtPhone"
                                         Mask="+7(000)000-00-00"
                                         FontSize="14"
                                         Height="30"
                                         Background="White"
                                         Foreground="Black"
                                         BorderBrush="#CCCCCC"
                                         BorderThickness="1"
                                         PromptChar="_"/>

                                <TextBlock Text="Email:" FontWeight="Bold" Foreground="Black" Margin="0,10,0,5"/>
                                <TextBox x:Name="txtEmail" FontSize="14" Padding="5" Height="30"
                                         Background="White"/>

                                <TextBlock Text="Город:" FontWeight="Bold" Foreground="Black" Margin="0,10,0,5"/>
                                <TextBox x:Name="txtCity" FontSize="14" Padding="5" Height="30"
                                         Background="White"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Адрес:" FontWeight="Bold" Foreground="Black" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtAddress" FontSize="14" Padding="5" Height="30"
                                 Background="White"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Border CornerRadius="20" 
                            BorderThickness="1" 
                            Height="45" 
                            Width="170"
                            Background="#444444"
                            Margin="0,0,20,0">
                        <Button x:Name="btnSave" 
                                Content="СОХРАНИТЬ" 
                                Click="SaveButton_Click"
                                Style="{StaticResource ButtonStyle}"        
                                FontWeight="Bold"
                                FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                            BorderThickness="1" 
                            Height="45" 
                            Width="150"
                            Background="#6E0A0F"
                            Margin="0,0,0,0">
                        <Button x:Name="btnClose" 
                                Content="ЗАКРЫТЬ" 
                                Click="CloseButton_Click"
                                Style="{StaticResource ButtonStyleTWO}"
                                FontWeight="Bold"
                                FontSize="25"/>
                    </Border>
                </StackPanel>

                <TextBlock Text="* - обязательные поля для заполнения" 
                           FontSize="12" 
                           Foreground="#FFD700" 
                           FontWeight="Bold"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>