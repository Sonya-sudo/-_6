<Window x:Class="Клуб_6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6"
        mc:Ignorable="d"
        Title="MainWindow" 
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <Grid>
            <!-- Используем Grid для центрирования -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Блок с логотипом -->
                <Image Source="/Изображения/лого.png" 
               Width="400" 
               Height="300" 
               Margin="-57,-131,-57,-68"
               HorizontalAlignment="Center"/>

                <!-- Блок с кнопками меню -->
                <StackPanel Height="415" Width="796" HorizontalAlignment="Center">
                    <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="55" 
                Width="410"
                Background="#08541C"
                Margin="0,25,0,0"
                HorizontalAlignment="Center">
                        <Button x:Name="btnRegistry" 
                    Content="СОБАКИ" 
                    Click="MenuButton_Click"
                    Style="{StaticResource ButtonStyle}"
                    FontWeight="Bold"
                    FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="55" 
                Width="410"
                Background="#08541C"
                Margin="0,15,0,0"
                HorizontalAlignment="Center">
                        <Button x:Name="btnOwners" 
                    Content="ВЛАДЕЛЬЦЫ" 
                    Click="MenuButton_Click"
                    FontWeight="Bold"
                    Style="{StaticResource ButtonStyle}"
                    FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="55" 
                Width="410"
                Background="#08541C"
                Margin="0,15,0,0"
                HorizontalAlignment="Center">
                        <Button x:Name="btnNursery" 
                    Content="ПИТОМНИКИ" 
                    Click="MenuButton_Click"
                    Style="{StaticResource ButtonStyle}"
                    FontWeight="Bold"
                    FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="55" 
                Width="410"
                Background="#08541C"
                Margin="0,15,0,0"
                HorizontalAlignment="Center">
                        <Button x:Name="btnCalendar" 
                    Content="КАЛЕНДАРЬ МЕРОПРИЯТИЙ" 
                    Click="MenuButton_Click"
                    Style="{StaticResource ButtonStyle}"
                    FontWeight="Bold"
                    FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="45" 
                Width="150"
                Background="#6E0A0F"
                Margin="0,15,0,0"
                HorizontalAlignment="Center">
                        <Button x:Name="btnExit" 
                    Content="ВЫХОД" 
                    Click="btnExit_Click"
                    Style="{StaticResource ButtonStyleTWO}"
                    FontWeight="Bold"
                    FontSize="25"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
