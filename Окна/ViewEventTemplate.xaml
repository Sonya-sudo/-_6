<Window x:Class="Клуб_6.Окна.ViewEventTemplate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ПРОСМОТР ШАБЛОНА"
        WindowState="Maximized"
        WindowStyle="None"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Border Background="#76AF2C">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Margin="0,20,0,10">
                <TextBlock x:Name="txtTitle" 
                           Text="ПРОСМОТР ШАБЛОНА МЕРОПРИЯТИЯ" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtTemplateName" 
                           Text="" 
                           FontSize="18" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Основной контент -->
            <ScrollViewer Grid.Row="1" Margin="20">
                <StackPanel>
                    <!-- Дисциплины -->
                    <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="#08541C" CornerRadius="10,10,0,0" Padding="15">
                                <TextBlock Text="ДИСЦИПЛИНЫ" 
                                           HorizontalAlignment="Center" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>

                            <ListView x:Name="lvDisciplines" 
                                      Margin="0,20,0,0" 
                                      FontSize="14"
                                      BorderThickness="0"
                                      AlternationCount="2">
                                <ListView.Resources>
                                    <Style TargetType="ListViewItem">
                                        <Style.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                <Setter Property="Background" Value="#F9F9F9"/>
                                            </Trigger>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Resources>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Название дисциплины" Width="300" DisplayMemberBinding="{Binding DisciplineName}"/>
                                        <GridViewColumn Header="Коэффициент" Width="150" DisplayMemberBinding="{Binding Coefficient}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock x:Name="txtNoDisciplines" 
                                       Text="Дисциплины не добавлены" 
                                       FontSize="14" 
                                       FontStyle="Italic"
                                       Foreground="Gray"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Критерии -->
                    <Border Background="White" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <Border Background="#08541C" CornerRadius="10,10,0,0" Padding="15">
                                <TextBlock Text="КРИТЕРИИ" 
                                           HorizontalAlignment="Center" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>

                            <ListView x:Name="lvCriteria" 
                                      Margin="0,20,0,0" 
                                      FontSize="14"
                                      BorderThickness="0"
                                      AlternationCount="2">
                                <ListView.Resources>
                                    <Style TargetType="ListViewItem">
                                        <Style.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                <Setter Property="Background" Value="#F9F9F9"/>
                                            </Trigger>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Resources>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Название критерия" Width="250" DisplayMemberBinding="{Binding CriterionName}"/>
                                        <GridViewColumn Header="Тип" Width="100" DisplayMemberBinding="{Binding Type}"/>
                                        <GridViewColumn Header="Варианты ответа" Width="350" DisplayMemberBinding="{Binding Options}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock x:Name="txtNoCriteria" 
                                       Text="Критерии не добавлены" 
                                       FontSize="14" 
                                       FontStyle="Italic"
                                       Foreground="Gray"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,30">
                <Button Content="ЗАКРЫТЬ" 
                        Width="200" 
                        Height="45" 
                        FontSize="20"
                        FontWeight="Bold"
                        Click="btnClose_Click"
                        Style="{StaticResource ButtonStyle}"
                        Margin="10"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>