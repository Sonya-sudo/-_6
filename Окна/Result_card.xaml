<Window x:Class="Клуб_6.Окна.Result_card"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Карточка мероприятия"
        Icon="/Изображения/лапа.jpg"
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Margin="0,20,0,10">
                <TextBlock x:Name="txtTitle" 
                           Text="КАРТОЧКА МЕРОПРИЯТИЯ" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Основной контент -->
            <ScrollViewer Grid.Row="1" Margin="20">
                <StackPanel>
                    <!-- Информация о мероприятии -->
                    <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#08541C" CornerRadius="10,10,0,0" Padding="15">
                                <TextBlock Text="ИНФОРМАЦИЯ О МЕРОПРИЯТИИ" 
                                           HorizontalAlignment="Center" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,20,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Левая колонка -->
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="Название:" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Margin="0,0,10,10"/>
                                <TextBlock x:Name="txtName" 
                                           Grid.Row="0" Grid.Column="1" 
                                           FontSize="16"
                                           Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="Дата:" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Margin="0,0,10,10"/>
                                <TextBlock x:Name="txtEventDate" 
                                           Grid.Row="1" Grid.Column="1" 
                                           FontSize="16"
                                           Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                           Text="Место:" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Margin="0,0,10,0"/>
                                <TextBlock x:Name="txtEventVenue" 
                                           Grid.Row="2" Grid.Column="1" 
                                           FontSize="16"/>

                                <!-- Правая колонка -->
                                <TextBlock Grid.Row="0" Grid.Column="2" 
                                           Text="Состав:" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Margin="20,0,10,10"/>
                                <TextBlock x:Name="txtComposition" 
                                           Grid.Row="0" Grid.Column="3" 
                                           FontSize="16"
                                           Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" 
                                           Text="Организация:" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Margin="20,0,10,10"/>
                                <TextBlock x:Name="txtOrganization" 
                                           Grid.Row="1" Grid.Column="3" 
                                           FontSize="16"
                                           Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Grid.Column="2" 
                                           Text="Статус:" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Margin="20,0,10,0"/>
                                <TextBlock x:Name="txtStatus" 
                                           Grid.Row="2" Grid.Column="3" 
                                           FontSize="16"/>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Судьи:" FontWeight="Bold" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                <TextBlock x:Name="txtJudges" Grid.Column="1" FontSize="16" TextWrapping="Wrap" VerticalAlignment="Top"/>
                             </Grid>
                        </Grid>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="#08541C" CornerRadius="10,10,0,0" Padding="15">
                                <TextBlock Text="ИНФОРМАЦИЯ О СОБАКАХ" 
                       HorizontalAlignment="Center" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="White"/>
                            </Border>

                            <ScrollViewer VerticalScrollBarVisibility="Disabled" 
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="None"
                      CanContentScroll="False">
                                <ListView x:Name="lvDogResults" 
                      Margin="0,20,0,0" 
                      FontSize="14"
                      BorderThickness="0"
                      SelectionMode="Single"
                      AlternationCount="2"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.Resources>
                                        <Style TargetType="ListViewItem">
                                            <Style.Triggers>
                                                <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                    <Setter Property="Background" Value="#F9F9F9"/>
                                                </Trigger>
                                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="#FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E0F0E0"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.Resources>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Собака" Width="180" DisplayMemberBinding="{Binding DogName}"/>
                                            <GridViewColumn Header="Чип" Width="120" DisplayMemberBinding="{Binding ChipNumber}"/>
                                            <GridViewColumn Header="Порода" Width="200" DisplayMemberBinding="{Binding Breed}"/>
                                            <GridViewColumn Header="Владелец" Width="200" DisplayMemberBinding="{Binding Owner}"/>
                                            <GridViewColumn Header="Результат" Width="300">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ResultText}" 
                                               Foreground="{Binding ResultColor}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </ScrollViewer>

                            <TextBlock x:Name="txtNoDogs" 
                   Text="В мероприятии нет собак" 
                   FontSize="16" 
                   FontStyle="Italic"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"
                   Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>


                    <!-- ТАБЛИЦА РЕЗУЛЬТАТОВ ПО ДИСЦИПЛИНАМ -->
                    <Border Background="White" CornerRadius="10" Padding="20" Margin="0,20,0,20">
                        <StackPanel>
                            <Border Background="#08541C" CornerRadius="10,10,0,0" Padding="15">
                                <TextBlock Text="ТАБЛИЦА РЕЗУЛЬТАТОВ ПО ДИСЦИПЛИНАМ" 
                       HorizontalAlignment="Center" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="White"/>
                            </Border>

                            <ListView x:Name="lvDisciplinesTable" 
                  Margin="0,20,0,0" 
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  AlternationCount="2">
                                <ListView.Resources>
                                    <Style TargetType="ListViewItem">
                                        <Style.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                <Setter Property="Background" Value="#F9F9F9"/>
                                            </Trigger>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Resources>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Дисциплина" Width="150" DisplayMemberBinding="{Binding DogName}"/>
                                        <!-- Динамические колонки для собак будут добавлены программно -->
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- ТАБЛИЦА РЕЗУЛЬТАТОВ ПО КРИТЕРИЯМ -->
                    <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="#08541C" CornerRadius="10,10,0,0" Padding="15">
                                <TextBlock Text="ТАБЛИЦА РЕЗУЛЬТАТОВ ПО КРИТЕРИЯМ" 
                       HorizontalAlignment="Center" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="White"/>
                            </Border>

                            <ListView x:Name="lvCriteriaTable" 
                  Margin="0,20,0,0" 
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  AlternationCount="2">
                                <ListView.Resources>
                                    <Style TargetType="ListViewItem">
                                        <Style.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                <Setter Property="Background" Value="#F9F9F9"/>
                                            </Trigger>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Resources>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Критерий" Width="200" DisplayMemberBinding="{Binding CriterionName}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>


                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,30">
                <Button Content="ЗАКРЫТЬ" 
                        Width="200" 
                        Height="45" 
                        FontSize="20"
                        FontWeight="Bold"
                        Click="btnClose_Click"
                        Style="{StaticResource ButtonStyle}"
                        Margin="10"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>