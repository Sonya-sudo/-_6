<Window x:Class="Клуб_6.Окна.calendar_of_events"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="calendar_of_events" 
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <Grid>
            <Border Background="#B0E75B" 
            Height="400" 
            VerticalAlignment="Top"
            Margin="500,300,500,0"
            CornerRadius="15"
            Opacity="0.7"/>
            <!-- Используем Grid для центрирования -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Блок с логотипом -->
                <Image Source="/Изображения/лого.png" 
       Width="400"  
       Height="300" 
       Margin="-57,-14,-57,-68"
       HorizontalAlignment="Center"/>

                <Image Source="/Изображения/КМ.png" 
       Width="300" 
       Height="150" 
       Margin="-57,5,-57,-50"
       HorizontalAlignment="Center"/>
                <!-- Блок с кнопками меню -->
                <StackPanel Height="420" Width="796" HorizontalAlignment="Center" RenderTransformOrigin="0.498,0.65">
                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="55" 
                    Width="410"
                    Background="#08541C"
                    Margin="0,25,0,0"
                    HorizontalAlignment="Center">
                        <Button x:Name="btnCalendarOfEvents" 
                        Content="РАСПИСАНИЕ" 
                        Click="MenuButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        FontWeight="Bold"
                        FontSize="25"/>
                    </Border>

                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="55" 
                    Width="410"
                    Background="#08541C"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center">
                        <Button x:Name="btnRegistrationEvent" 
                        Content="РЕГИСТРАЦИЯ" 
                        Click="MenuButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        FontWeight="Bold" 
                        FontSize="25"/>
                    </Border>
                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="55" 
                    Width="410"
                    Background="#08541C"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center">
                        <Button x:Name="btnArchive" 
                        Content="АРХИВ МЕРОПРИЯТИЙ" 
                        Click="MenuButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        FontWeight="Bold" 
                        FontSize="25"/>
                    </Border>
                    <StackPanel Margin="195,15,0,0" Height="65" Orientation="Horizontal">

                        <Border CornerRadius="20" 
                        BorderThickness="1" 
                        Height="45" 
                        Width="150"
                        Background="#444444"
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left">
                            <Button x:Name="btnCalendar" 
                            Content="НАЗАД" 
                            Click="btnBack_Click"
                            Style="{StaticResource ButtonStyleTHREE}"
                            FontWeight="Bold"
                            FontSize="25" Height="43" VerticalAlignment="Top"/>
                        </Border>

                        <Border Background="Transparent"  Width="100"/>

                        <Border CornerRadius="20" 
                BorderThickness="1" 
                Height="45" 
                Width="150"
                Background="#6E0A0F"
                Margin="0,15,0,0">
                            <Button x:Name="btnExit" 
                    Content="ВЫХОД" 
                    Click="btnExit_Click"
                    Style="{StaticResource ButtonStyleTWO}"
                    FontWeight="Bold"
                    FontSize="25"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
