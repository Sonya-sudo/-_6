<Window x:Class="Клуб_6.Окна.ArchiveResult"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="ArchiveResult"     
        WindowState="Maximized"
        WindowStyle="None">
    <Border Background="#76AF2C">
        <Grid>
            <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                <Border CornerRadius="20" 
        BorderThickness="1" 
        Height="55" 
        Width="410"
        Background="#B0E75B"
        Margin="0,0,0,20"
        HorizontalAlignment="Center">
                    <TextBlock Text="АРХИВ МЕРОПРИЯТИЙ" 
               FontSize="24" 
               FontWeight="Bold"
               Foreground="Black"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
                </Border>

                <ListView Name="ArchiveList" 
               ItemsSource="{Binding ArchiveEvents}"
               FontSize="14"
               Height="670" 
               BorderThickness="0" 
               Width="1200"
               AlternationCount="2"
               Margin="0,10,0,0"
               SelectionMode="Single"
               SelectedItem="{Binding SelectedEvent}"
               MouseDoubleClick="ArchiveList_MouseDoubleClick">

                    <ListView.Resources>
                        <Style TargetType="{x:Type GridViewColumnHeader}">
                            <Setter Property="Background" Value="#08541C"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Height" Value="35"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="{x:Type ListViewItem}">
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                    <Setter Property="Background" Value="#C7C7C7"/>
                                </Trigger>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#ACDDE7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFD700"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Resources>

                    <ListView.View>
                        <GridView>
                            <!-- УБРАНЫ ЛИШНИЕ СТОЛБЦЫ -->
                            <GridViewColumn Header="Название" Width="300" DisplayMemberBinding="{Binding CompositionTitle}"/>
                            <GridViewColumn Header="Дата проведения" Width="120" DisplayMemberBinding="{Binding FormattedDate}"/>
                            <GridViewColumn Header="Место проведения" Width="250" DisplayMemberBinding="{Binding EventVenue}"/>
                            <GridViewColumn Header="Участники" Width="80" DisplayMemberBinding="{Binding DogsCount}"/>
                            <GridViewColumn Header="Статус" Width="120" DisplayMemberBinding="{Binding StatusName}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <Border CornerRadius="20" 
                 BorderThickness="1" 
                 Height="45" 
                 Width="180"
                 Background="#444444"
                 Margin="0,-25,0,0"
                 HorizontalAlignment="Left">
                        <Button x:Name="btnBack" 
                     Content="НАЗАД" 
                     Click="btnBack_Click"
                     Style="{StaticResource ButtonStyleTHREE}"
                     FontWeight="Bold"
                     FontSize="25"/>
                    </Border>

                    <Border Background="Transparent" Width="20"/>

                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="230"
                    Background="#444444"
                    Margin="0,-25,0,0"
                    HorizontalAlignment="Left" >
                        <Button x:Name="btnView" 
                        Content="ОТКРЫТЬ КАРТУ" 
                        Click="btnView_Click"
                        Style="{StaticResource ButtonStyleTHREE}"
                        FontWeight="Bold"
                        FontSize="25"/>
                    </Border>

                    <Border Background="Transparent" Width="20"/>

                    <Border CornerRadius="20" 
                 BorderThickness="1" 
                 Height="45" 
                 Width="180"
                 Background="#6E0A0F"
                 Margin="0,-25,0,0">
                        <Button x:Name="btnExit" 
                     Content="ВЫХОД" 
                     Click="btnExit_Click"
                     Style="{StaticResource ButtonStyleTWO}"
                     FontWeight="Bold"
                     FontSize="25"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>