<Window x:Class="Клуб_6.Окна.nursery_file"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="nursery_file"    
        WindowState="Maximized"
        WindowStyle="None">

    <Border Background="#76AF2C">
        <Grid>
            <!-- Используем Grid для центрирования -->
            <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0" >
                <TextBlock Text="КАРТОТЕКА ПИТОМНИКОВ" 
                   HorizontalAlignment="Center" 
                   FontSize="35" 
                   FontWeight="Bold"/>
                <Border Grid.Row="1" Margin="50,10,50,10" Background="White" CornerRadius="10">
                    <ListView Name="BoxNursery" 
                      ItemsSource="{Binding NurseryList}"
                      FontSize="14"
                      Height="670" 
                      BorderThickness="0" 
                      Width="1500"
                      AlternationCount="2"
                      Margin="0,10,0,0"
                      SelectionMode="Single">

                        <ListView.Resources>
                            <!-- Стиль для заголовков столбцов -->
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="Background" Value="#08541C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Height" Value="35"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="#C7C7C7"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#ACDDE7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название" Width="250" DisplayMemberBinding="{Binding KennelName}"/>
                                <GridViewColumn Header="Дата основания" Width="120" 
          DisplayMemberBinding="{Binding FoundationDate, StringFormat=dd.MM.yyyy}"/>
                                <GridViewColumn Header="Страна" Width="100" DisplayMemberBinding="{Binding Country}"/>
                                <GridViewColumn Header="Город" Width="100" DisplayMemberBinding="{Binding City}"/>
                                <GridViewColumn Header="Адрес" Width="200" DisplayMemberBinding="{Binding Address}"/>
                                <GridViewColumn Header="Телефон" Width="150" DisplayMemberBinding="{Binding Phone}"/>
                                <GridViewColumn Header="Email" Width="150" DisplayMemberBinding="{Binding Email}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="150"
                    Background="#444444"
                    Margin="0,-25,0,0"
                    HorizontalAlignment="Left">
                        <Button x:Name="btnCalendar" 
                        Content="НАЗАД" 
                        Click="btnBack_Click"
                        FontWeight="Bold"
                        FontSize="25"
                        Style="{StaticResource ButtonStyleTHREE}"/>
                    </Border>

                    <Border Background="Transparent"  Width="20"/>

                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="230"
                    Background="#444444"
                    Margin="0,-25,0,0"
                    HorizontalAlignment="Left" >
                        <Button x:Name="btnChange" 
                        Content="ОТКРЫТЬ КАРТУ" 
                        Click="btnChange_Click"
                        FontWeight="Bold"
                        FontSize="25"
                        Style="{StaticResource ButtonStyle}"/>
                    </Border>

                    <Border Background="Transparent"  Width="20"/>


                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="150"
                    Background="#6E0A0F"
                    Margin="0,-25,0,0">
                        <Button x:Name="btnDelete" 
                        Content="УДАЛИТЬ" 
                        Click="DeleteButton_Click"
                        Style="{StaticResource ButtonStyleTWO}"
                        FontWeight="Bold"
                        FontSize="25"/>
                    </Border>

                    <Border Background="Transparent"  Width="20"/>

                    <Border CornerRadius="20" 
                    BorderThickness="1" 
                    Height="45" 
                    Width="150"
                    Background="#6E0A0F"
                    Margin="0,-25,0,0">
                        <Button x:Name="btnExit" 
                        Content="ВЫХОД" 
                        Click="btnExit_Click"
                        FontWeight="Bold"
                        FontSize="25"
                        Style="{StaticResource ButtonStyleTWO}"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
