<Window x:Class="Клуб_6.Окна.owner_card"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Клуб_6.Окна"
        mc:Ignorable="d"
        Title="owner_card">
    <Border Background="#76AF2C">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Заголовок -->
                <TextBlock Text="КАРТОЧКА ВЛАДЕЛЬЦА" 
                FontSize="24" 
                FontWeight="Bold"
                Foreground="White"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"/>

                <!-- ФИО раздельно -->
                <TextBlock Text="ФИО" 
                FontSize="16" FontWeight="Bold" Foreground="White" 
                HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Фамилия -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Фамилия *:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtLastName" FontSize="14" Padding="5" Height="30"/>
                    </StackPanel>

                    <!-- Имя -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Имя *:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFirstName" FontSize="14" Padding="5" Height="30"/>
                    </StackPanel>

                    <!-- Отчество -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Отчество:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMiddleName" FontSize="14" Padding="5" Height="30"/>
                    </StackPanel>
                </Grid>

                <!-- Контактная информация -->
                <TextBlock Text="КОНТАКТНАЯ ИНФОРМАЦИЯ" 
                FontSize="16" FontWeight="Bold" Foreground="White" 
                HorizontalAlignment="Center" Margin="0,20,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка -->
                    <StackPanel Grid.Column="0">
                        <!-- Телефон * -->
                        <TextBlock Text="Телефон *:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <xctk:MaskedTextBox x:Name="txtPhone" 
                                     FontSize="14" 
                                     Padding="5" 
                                     Height="30"
                                     Mask="+7(000)000-00-00"
                                     PromptChar="_"/>

                        <!-- Email -->
                        <TextBlock Text="Email:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtEmail" FontSize="14" Padding="5" Height="30"/>

                        <!-- Дата рождения -->
                        <TextBlock Text="Дата рождения:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <DatePicker x:Name="dpBirthDate" FontSize="14" Height="30"/>
                    </StackPanel>

                    <!-- Правая колонка -->
                    <StackPanel Grid.Column="2">
                        <!-- Город -->
                        <TextBlock Text="Город:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCity" FontSize="14" Padding="5" Height="30"/>

                        <!-- Адрес -->
                        <TextBlock Text="Адрес проживания:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                        <TextBox x:Name="txtAddress" FontSize="14" Padding="5" Height="30"/>
                    </StackPanel>
                </Grid>

                <!-- Информация о собаках (только для просмотра) -->
                <TextBlock Text="СОБАКИ ВЛАДЕЛЬЦА" 
FontSize="16" FontWeight="Bold" Foreground="White" 
HorizontalAlignment="Center" Margin="0,20,0,10"/>

                <!-- Текстовое поле с перечислением собак -->
                <TextBlock Text="Список собак владельца:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDogs" FontSize="14" Padding="5" Height="60" 
  IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
  ToolTip="Собаки автоматически добавляются при регистрации"/>

                <!-- Детальный список собак -->
                <ListBox x:Name="lstOwnerDogs" Height="150" Margin="0,10,0,0"
                    MouseDoubleClick="LstOwnerDogs_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DogName}" FontWeight="Bold" Width="120"/>
                                <TextBlock Text="Порода: " Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding Breed}" Width="100"/>
                                <TextBlock Text="Чип: " Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding ChipNumber}" Width="80"/>
                                <TextBlock Text="Дата рожд.: " Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Border CornerRadius="20" 
                         BorderThickness="1" 
                         Height="45" 
                         Width="160"
                         Background="#444444"
                         Margin="0,0,20,0">
                        <Button x:Name="btnSave" 
                             Content="СОХРАНИТЬ" 
                             Click="SaveButton_Click"
                             FontWeight="Bold"
                             FontSize="20"
                            Style="{StaticResource ButtonStyle}"/>
                    </Border>

                    <Border CornerRadius="20" 
                         BorderThickness="1" 
                         Height="45" 
                         Width="150"
                         Background="#6E0A0F"
                         Margin="0,0,0,0">
                        <Button x:Name="btnClose" 
                             Content="ЗАКРЫТЬ" 
                             Click="CloseButton_Click"
                             FontWeight="Bold"
                             FontSize="20"
                             Style="{StaticResource ButtonStyleTWO}"
                        />
                    </Border>
                </StackPanel>

                <!-- Примечание -->
                <TextBlock Text="* - обязательные поля для заполнения" 
                FontSize="12" 
                Foreground="#FFD700" 
                FontWeight="Bold"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
